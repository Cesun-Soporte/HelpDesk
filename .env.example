# Server
PORT=5000
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/callback

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Database - PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/helpdesk_cesun

# Dominios Autorizados
ALLOWED_DOMAINS=cesunbc.edu.mx,cesun.edu.mx

# Email Configuration - Gmail
EMAIL_PROVIDER=gmail
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_app_gmail
EMAIL_FROM=tu_email@gmail.com

# Email Configuration - SMTP (opcional)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.tuproveedor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_usuario@tuproveedor.com
# SMTP_PASSWORD=tu_contraseña
# EMAIL_FROM=tu_email@tuproveedor.com
