{
  "name": "helpdesk-cesun",
  "version": "1.0.0",
  "description": "Sistema de Help Desk Institucional CESUN",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm install && npm run build",
    "start": "node server.js",
    "init-db": "node init-db.js",
    "vercel-build": "npm --prefix client install && npm --prefix client run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "google-auth-library": "^9.0.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.10.0",
    "socket.io": "^4.5.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^7.6.0"
  }
}
